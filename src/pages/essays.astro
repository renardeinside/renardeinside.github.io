---
import Base from "../layouts/Base.astro";
import { Undo2 } from "lucide-svelte";

const essays = await Astro.glob("../essays/*.mdx");
---

<Base>
    <a href="/" class="absolute top-0 right-0 h-16 w-16 m-4">
        <div class="tooltip tooltip-bottom w-4" data-tip="Back to profile">
            <button class="btn btn-primary btn-circle btn-outline"
                ><Undo2 /></button
            >
        </div>
    </a>
    <div class="container mx-auto p-4">
        <article class="prose">
            <h1 class="text-4xl font-bold text-white">Essays</h1>
        </article>
        <div class="text-2xl flex justify-center items-center min-h-[50vh]">There is nothing here yet. Please check back later.</div>
    </div>
</Base>
